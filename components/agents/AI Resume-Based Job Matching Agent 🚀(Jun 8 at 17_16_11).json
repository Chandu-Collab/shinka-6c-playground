        "id": "3e416a9d-65c8-4ab0-9a6e-76471df859c5",
        "name": "Resume Text Parser"
      },
      {
        "parameters": {
          "httpMethod": "POST",
          "path": "3a6ef633-336b-4198-b944-abde42f1549a",
          "options": {}
        },
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 2.1,
        "position": [
          -384,
          32
        ],
        "id": "e2776b17-57e4-47ff-9f94-cebf9bee7ab6",
        "name": "Data Input",
        "webhookId": "3a6ef633-336b-4198-b944-abde42f1549a"
      },
      {
        "parameters": {
          "promptType": "define",
          "text": "=Extract structured data from this resume:\n\n{{ $json.resumeText }}",
          "hasOutputParser": true,
          "options": {
            "systemMessage": "You are a resume parsing AI designed for automation workflows.\n\nYour task is to extract structured data from a resume.\n\nRules:\n- Return ONLY valid JSON\n- Do NOT include any explanation, text, or formatting outside JSON\n- Ensure JSON is parseable\n- If data is missing, return empty arrays\n\nExtract the following fields:\n- skills (array of strings)\n- inferred_skills (array of strings based on context)\n- roles (array of job roles)\n- experience_level (\"fresher\", \"junior\", \"mid\", \"senior\")\n\nFor freshers:\n- Infer skills from projects and technologies mentioned\n- Map technologies to roles (e.g., React → Frontend Developer)\n\nOutput format:\n{\n  \"skills\": [],\n  \"inferred_skills\": [],\n  \"roles\": [],\n  \"experience_level\": \"\"\n}"
          }
        },
        "type": "@n8n/n8n-nodes-langchain.agent",
        "typeVersion": 3.1,
        "position": [
          32,
          16
        ],
        "id": "9c585b9d-5240-41b9-8bde-4e22434a83e7",
        "name": "Skill Extractor"
      },
      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "let raw = $json.output;\n\n// ensure string\nif (typeof raw !== \"string\") {\n  raw = JSON.stringify(raw);\n}\n\n// clean markdown\nraw = raw.replace(/```json|```/g, '').trim();\n\n// parse\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (err) {\n  throw new Error(\"Parsing failed. Raw output: \" + raw);\n}\n\n// merge + normalize\nconst allSkills = [\n  ...(parsed.skills || []),\n  ...(parsed.inferred_skills || [])\n];\n\nconst normalized = [...new Set(allSkills.map(s => s.toLowerCase()))];\n\n// ✅ RETURN ONLY OBJECT (NOT ARRAY, NOT json wrapper)\nreturn {\n  skills: normalized,\n  roles: parsed.roles || [],\n  experience_level: parsed.experience_level || \"fresher\"\n};"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          416,
          16
        ],
        "id": "79c90588-bda7-4b30-869a-424b53d7d907",
        "name": "Profile Builder"
      },
      {
        "parameters": {
          "url": "https://remotive.com/api/remote-jobs",
          "sendQuery": true,
          "queryParameters": {
            "parameters": [
              {
                "name": "search",
                "value": "={{$json.skills.join(\" \")}}"
              },
              {}
            ]
          },
          "options": {}
        },
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.4,
        "position": [
          832,
          80
        ],
        "id": "1fa5baac-35ef-4371-854d-a365d9cf4713",
        "name": "Job Fetcher"
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\n\n// 🔹 Extract data from different inputs\nconst userSkills = items[0].json.skills || [];\nconst jobs = items[1].json.jobs || [];\n\nif (!userSkills.length || !jobs.length) {\n  return [\n    {\n      json: {\n        error: \"Missing skills or jobs\",\n        userSkills,\n        jobsCount: jobs.length\n      }\n    }\n  ];\n}\n\nconst fresherKeywords = [\"junior\", \"entry\", \"fresher\", \"graduate\", \"intern\"];\n\nlet processed = jobs.map(job => {\n  let score = 0;\n  const desc = (job.description || \"\").toLowerCase();\n  const title = (job.title || \"\").toLowerCase();\n\n  userSkills.forEach(skill => {\n    if (desc.includes(skill.toLowerCase())) {\n      score++;\n    }\n  });\n\n  let fresherMatch = fresherKeywords.some(keyword =>\n    title.includes(keyword) || desc.includes(keyword)\n  );\n\n  return {\n    title: job.title,\n    company: job.company_name,\n    link: job.url,\n    description: job.description,\n    skills: userSkills,\n    matchScore: score,\n    fresherMatch\n  };\n});\n\n// 🔥 STEP 1: fresher filter\nlet filtered = processed\n  .filter(job => job.matchScore >= 2 && job.fresherMatch)\n  .sort((a, b) => b.matchScore - a.matchScore)\n  .slice(0, 5);\n\n// 🔥 STEP 2: fallback\nif (filtered.length === 0) {\n  filtered = processed\n    .filter(job => job.matchScore >= 2)\n    .sort((a, b) => b.matchScore - a.matchScore)\n    .slice(0, 5);\n}\n\nreturn filtered.map(job => ({ json: job }));"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1264,
          32
        ],
        "id": "db1c210a-b3ac-4214-991c-32414aeeb904",
        "name": "Job Normalizer"
      },
      {
        "parameters": {
          "promptType": "define",
          "text": "=Candidate skills:\n{{ $json.skills }}\n\nJob Title:\n{{ $json.title }}\n\nCompany:\n{{ $json.company }}\n\nJob Description:\n{{ $json.description }}\n\nIMPORTANT:\nReturn response in JSON format:\n{\n  \"explanation\": \"...\"\n}",
          "options": {
            "systemMessage": "You are an AI career assistant.\n\nYour task is to explain why a job is suitable for a candidate based on their skills.\n\nRules:\n- Keep it short (2-3 lines)\n- Be clear and specific\n- Mention relevant skills\n- Make it sound helpful for freshers\n- Do NOT hallucinate skills not provided"
          }
        },
        "type": "@n8n/n8n-nodes-langchain.agent",
        "typeVersion": 3.1,
        "position": [
          1520,
          96
        ],
        "id": "e99a2aef-d672-480a-9e4c-6a435057f039",
        "name": "Explanation Generator"
      },
      {
        "parameters": {
          "mode": "runOnceForEachItem",
          "jsCode": "let raw = $json.output;\n\nif (typeof raw === \"string\") {\n  raw = raw.replace(/```json|```/g, \"\").trim();\n}\n\nlet parsed = JSON.parse(raw);\n\nreturn {\n  json: {\n    title: $json.title,\n    company: $json.company,\n    link: $json.link,\n    explanation: parsed.explanation\n  }\n};"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          2096,
          0
        ],
        "id": "35d23e19-784a-4475-bdab-2f509169b159",
        "name": "Ai Career Insights Generator"
      },
      {
        "parameters": {
          "jsCode": "const items = $input.all();\n\n// get email from first item\nconst email = items[0].json.email;\n\n// build message\nconst message = items.map((item, i) => {\n  return `${i + 1}. ${item.json.title} (${item.json.company})\n\n💡 Why it matches:\n${item.json.explanation}\n\n🔗 Apply:\n${item.json.link}`;\n}).join(\"\\n\\n----------------------\\n\\n\");\n\n// return SINGLE item\nreturn [\n  {\n    json: {\n      email,\n      message\n    }\n  }\n];"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
